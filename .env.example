# Database
MONGODB_URI=mongodb://localhost:27017/cryptowithalgo

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Binance API (configurable for proxy/geo-restrictions)
BINANCE_API_URL=https://api.binance.com/api/v3
NEXT_PUBLIC_BINANCE_WS_URL=wss://stream.binance.com:9443
BINANCE_FUTURES_API_URL=https://fapi.binance.com

# CryptoPanic (news feed)
CRYPTOPANIC_API_TOKEN=

# Admin
ADMIN_EMAIL=

# Cron
CRON_SECRET=

# Registration gate -- set to "true" to allow new account sign-ups
# (disabled by default; required to create your first account)
ALLOW_REGISTRATION=

# Seed script (npm run seed) -- demo user display name
SEED_NAME=

# Email (MailerSend SMTP)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CryptoWithAlgo <noreply@cryptowithalgo.com>

# Cloudflare Turnstile (anti-spam on email-sending endpoints)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
