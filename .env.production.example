# =============================================================================
# Production Environment Variables
# Copy this file to .env.production and fill in the values.
# =============================================================================

# -- Domain --
# Your domain name (used by Caddy for auto-HTTPS)
DOMAIN=yourdomain.com

# -- MongoDB --
# Root credentials (used to initialize MongoDB on first run)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_root_password

# Application database user (created by docker/mongo-init.js)
MONGO_APP_USER=appuser
MONGO_APP_PASSWORD=CHANGE_ME_strong_app_password

# Connection string used by the Next.js app (must match MONGO_APP_USER/PASSWORD)
MONGODB_URI=mongodb://appuser:CHANGE_ME_strong_app_password@crypto-mongodb-prod:27017/cryptowithalgo?authSource=cryptowithalgo

# -- Redis (Upstash) --
# Upstash is a hosted Redis service (HTTP-based, no local Redis container needed)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# -- NextAuth --
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_generate_a_secret
NEXTAUTH_URL=https://yourdomain.com

# -- OAuth Providers (optional) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -- Binance API --
# Runtime: REST API base URL
BINANCE_API_URL=https://api.binance.com/api/v3
BINANCE_FUTURES_API_URL=https://fapi.binance.com

# Build-time: WebSocket URL (also set in docker-compose.prod.yml build args)
NEXT_PUBLIC_BINANCE_WS_URL=wss://stream.binance.com:9443

# -- Cron --
# Bearer token for cron job authentication. Generate with: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_generate_a_cron_secret
